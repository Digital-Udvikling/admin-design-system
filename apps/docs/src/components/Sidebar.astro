---
const pathname = Astro.url.pathname.replace(/\/$/, "") || "/";

const sections = [
  {
    title: "Vanilla CSS",
    links: [
      { href: "/vanilla", label: "Overview" },
      { href: "/vanilla/buttons", label: "Buttons" },
      { href: "/vanilla/inputs", label: "Inputs" },
      { href: "/vanilla/cards", label: "Cards" },
    ],
  },
  {
    title: "React",
    links: [
      { href: "/react", label: "Overview" },
      { href: "/react/buttons", label: "Buttons" },
      { href: "/react/inputs", label: "Inputs" },
      { href: "/react/cards", label: "Cards" },
    ],
  },
];
---

<aside class="w-64 shrink-0 border-r border-border bg-surface-muted px-5 py-8">
  <a href="/" class="block mb-8">
    <span class="text-base font-semibold">@aortl/admin</span>
    <span class="block text-xs text-text-muted mt-0.5">design system</span>
  </a>

  <nav class="flex flex-col gap-6">
    {sections.map((section) => (
      <div>
        <h2 class="text-xs uppercase tracking-wider text-text-muted font-semibold mb-2">
          {section.title}
        </h2>
        <ul class="flex flex-col gap-0.5">
          {section.links.map((link) => {
            const isActive = pathname === link.href;
            return (
              <li>
                <a
                  href={link.href}
                  class:list={[
                    "block px-2 py-1 rounded-control text-sm",
                    isActive
                      ? "bg-primary text-primary-content"
                      : "text-text hover:bg-surface-strong",
                  ]}
                >
                  {link.label}
                </a>
              </li>
            );
          })}
        </ul>
      </div>
    ))}
  </nav>
</aside>
