{
  "name": "@aortl/admin-css",
  "version": "0.2.0",
  "description": "Pre-built CSS design system. Drop in via <link> and use semantic class names.",
  "keywords": [
    "components",
    "css",
    "design-system",
    "tailwind"
  ],
  "homepage": "https://digital-udvikling.github.io/admin-design-system/",
  "bugs": "https://github.com/Digital-Udvikling/admin-design-system/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Digital-Udvikling/admin-design-system.git",
    "directory": "packages/admin-css"
  },
  "style": "./dist/admin.css",
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "main": "./dist/admin.css",
  "exports": {
    ".": "./dist/admin.css",
    "./admin.css": "./dist/admin.css",
    "./admin.min.css": "./dist/admin.min.css",
    "./admin.scoped.css": "./dist/admin.scoped.css",
    "./admin.scoped.min.css": "./dist/admin.scoped.min.css",
    "./src/*": "./src/*"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "pnpm build:dev && pnpm build:min && pnpm build:scoped",
    "build:dev": "tailwindcss -i ./src/admin.css -o ./dist/admin.css",
    "build:min": "tailwindcss -i ./src/admin.css -o ./dist/admin.min.css --minify",
    "build:scoped": "node ./scripts/wrap-scoped.mjs",
    "dev": "tailwindcss -i ./src/admin.css -o ./dist/admin.css --watch",
    "prepublishOnly": "pnpm build"
  },
  "devDependencies": {
    "@tailwindcss/cli": "4.3.0",
    "postcss": "8.5.15",
    "tailwindcss": "4.3.0"
  }
}
