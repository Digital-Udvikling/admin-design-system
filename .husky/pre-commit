set -e

pnpm lint
pnpm format:check
pnpm check-types

# Mirrors CI's skills/ drift check, surfaced before the push.
if git diff --cached --name-only \
  | grep -qE '^(apps/docs/src/content/docs/|apps/docs/scripts/generate-skill\.mjs$|apps/docs/scripts/skill-header\.md$|skills/)'; then
  pnpm generate-skill
  if ! git diff --quiet -- skills; then
    echo
    echo "skills/ is out of sync with apps/docs/src/content/docs/."
    echo "The bundle has been regenerated — review, 'git add skills', and re-commit."
    exit 1
  fi
fi
