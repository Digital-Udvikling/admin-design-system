---
import { Code, TabItem, Tabs } from "@astrojs/starlight/components";

interface Props {
  /** Pre-formatted HTML source. Drives the vanilla preview and the HTML tab. */
  html?: string;
  /** Pre-formatted React source. Drives the React tab. */
  react?: string;
  /**
   * When set, the React preview island renders its own ControlsPanel and a
   * live-updating source block (substituting current control values). The
   * source-tabs area below is then HTML-only — there's no static React
   * `<Code>` to render because the live one lives inside the island.
   */
  hasControls?: boolean;
}

const { html, react, hasControls } = Astro.props;
const hasReact = !!react;
const hasBoth = !!html && hasReact;
const showReactSource = hasReact && !hasControls;
const showSourceTabs = !!html && showReactSource;
const hasSource = showSourceTabs || !!html || showReactSource;
---

<section class="not-content example-block">
  <div class="example-frame">
    {
      hasBoth ? (
        <package-preview class:list={["example-preview", hasControls && "example-preview-stacked"]}>
          <div class="preview-variant" data-variant="html">
            {hasControls ? (
              <div class="example-preview-body" set:html={html!} />
            ) : (
              <Fragment set:html={html!} />
            )}
          </div>
          <div class="preview-variant" data-variant="react" hidden>
            <slot name="preview" />
          </div>
        </package-preview>
      ) : (
        <div class:list={["example-preview", hasControls && "example-preview-stacked"]}>
          {hasReact ? (
            <slot name="preview" />
          ) : html ? (
            <Fragment set:html={html} />
          ) : null}
        </div>
      )
    }
    {
      hasSource && (
        <div class="example-source">
          {showSourceTabs ? (
            <Tabs syncKey="package">
              <TabItem label="Vanilla CSS">
                <Code code={html!} lang="html" />
              </TabItem>
              <TabItem label="React">
                <Code code={react!} lang="tsx" />
              </TabItem>
            </Tabs>
          ) : html ? (
            <Code code={html} lang="html" />
          ) : showReactSource ? (
            <Code code={react!} lang="tsx" />
          ) : null}
        </div>
      )
    }
  </div>
</section>

{/* Hoisted module so Astro bundles and dedupes it across the page. The
storage key, sync attribute, and tab selectors below intentionally track
@astrojs/starlight/user-components/Tabs.astro — keep them in sync. */}
<script>
  const STORAGE_KEY = "starlight-synced-tabs__package";

  class PackagePreview extends HTMLElement {
    #observer: MutationObserver | null = null;
    #onStorage = (e: StorageEvent) => {
      if (e.key === STORAGE_KEY && e.newValue) this.#apply(e.newValue);
    };

    connectedCallback() {
      if (this.querySelectorAll(".preview-variant").length < 2) return;

      const stored = localStorage.getItem(STORAGE_KEY);
      if (stored) this.#apply(stored);

      const tabs = this.parentElement?.querySelector(
        'starlight-tabs[data-sync-key="package"]',
      );
      if (tabs) {
        this.#observer = new MutationObserver(() => {
          const tab = tabs.querySelector('[role="tab"][aria-selected="true"]');
          const label = tab?.textContent?.trim();
          if (label) this.#apply(label);
        });
        this.#observer.observe(tabs, {
          attributes: true,
          attributeFilter: ["aria-selected"],
          subtree: true,
        });
      }

      window.addEventListener("storage", this.#onStorage);
    }

    disconnectedCallback() {
      this.#observer?.disconnect();
      this.#observer = null;
      window.removeEventListener("storage", this.#onStorage);
    }

    #apply(label: string) {
      const wantReact = label === "React";
      for (const v of this.querySelectorAll<HTMLElement>(".preview-variant")) {
        const isReact = v.dataset.variant === "react";
        v.hidden = wantReact ? !isReact : isReact;
      }
    }
  }

  customElements.define("package-preview", PackagePreview);
</script>

<style>
  .example-block {
    margin: 1.5rem 0 2rem;
  }
  .example-frame {
    border: 1px solid var(--sl-color-hairline);
    border-radius: 0.5rem;
    overflow: hidden;
    background: var(--sl-color-bg);
  }
  .example-preview {
    padding: 1.5rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem;
    border-bottom: 1px solid var(--sl-color-hairline);
    background: var(--color-surface);
  }
  /* Variants are layout-transparent so children flex directly in the
  preview. The explicit [hidden] rule outranks display: contents. */
  .example-preview .preview-variant {
    display: contents;
  }
  .example-preview .preview-variant[hidden] {
    display: none;
  }
  /* When controls are present, the outer preview is a vertical stack of
  three sections (controls strip, preview body, live source). Variants
  become normal blocks so each section sits on its own row, and the body's
  padding/flex-center moves down to .example-preview-body (rendered both in
  the React island and around the static HTML wrap above). */
  .example-preview-stacked {
    display: block;
    padding: 0;
    gap: 0;
  }
  .example-preview-stacked .preview-variant {
    display: block;
  }
  .example-preview-stacked .preview-variant[hidden] {
    display: none;
  }
  .example-preview-stacked :global(.example-preview-body) {
    padding: 1.5rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem;
    background: var(--color-surface);
  }
  .example-preview-stacked :global(.example-controls) {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem 1rem;
    align-items: end;
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--sl-color-hairline);
    background: var(--sl-color-bg-nav);
  }
  .example-preview-stacked :global(.example-control) {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    min-width: 8rem;
  }
  .example-preview-stacked :global(.example-control-label) {
    color: var(--sl-color-gray-2);
    font-size: 0.75rem;
    text-transform: capitalize;
    letter-spacing: 0.02em;
  }
  .example-preview-stacked :global(.example-live-source) {
    margin: 0;
    padding: 0.75rem 1rem;
    border-top: 1px solid var(--sl-color-hairline);
    background: var(--sl-color-gray-6);
    color: var(--sl-color-white);
    font-size: 0.8125rem;
    line-height: 1.5;
    overflow-x: auto;
    white-space: pre;
    border-radius: 0;
  }
  .example-source :global(starlight-tabs),
  .example-source :global(div[role="tabpanel"]) {
    margin-top: 0;
  }
  .example-source :global(.tablist-wrapper) {
    background: var(--sl-color-bg-nav);
  }
  .example-source :global(pre) {
    margin: 0;
    border-radius: 0;
    border: none;
  }
</style>
