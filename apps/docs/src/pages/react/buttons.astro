---
import { Button } from "@aortl/admin-react";
import Example from "../../components/Example.astro";
import Layout from "../../layouts/Layout.astro";
---

<Layout title="React — Buttons">
  <h1 class="text-3xl font-bold mb-2">Button</h1>
  <p class="text-text-muted text-lg mb-8">
    Variants and sizes as props. Renders the same DOM as the vanilla examples.
  </p>

  <Example
    title="Variants"
    lang="tsx"
    code={`<Button variant="primary">Primary</Button>
<Button variant="secondary">Secondary</Button>
<Button variant="ghost">Ghost</Button>
<Button variant="danger">Danger</Button>`}
  >
    <Button variant="primary">Primary</Button>
    <Button variant="secondary">Secondary</Button>
    <Button variant="ghost">Ghost</Button>
    <Button variant="danger">Danger</Button>
  </Example>

  <Example
    title="Sizes"
    lang="tsx"
    code={`<Button size="sm">Small</Button>
<Button>Medium</Button>
<Button size="lg">Large</Button>`}
  >
    <Button size="sm">Small</Button>
    <Button>Medium</Button>
    <Button size="lg">Large</Button>
  </Example>

  <Example
    title="Disabled"
    lang="tsx"
    code={`<Button disabled>Disabled</Button>
<Button variant="secondary" disabled>Disabled</Button>`}
  >
    <Button disabled>Disabled</Button>
    <Button variant="secondary" disabled>Disabled</Button>
  </Example>

  <Example
    title="Block (full width)"
    lang="tsx"
    code={`<Button block>Continue</Button>`}
  >
    <div class="w-full max-w-sm">
      <Button block>Continue</Button>
    </div>
  </Example>
</Layout>
