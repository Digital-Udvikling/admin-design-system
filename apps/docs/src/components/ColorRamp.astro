---
interface Tone {
  label: string;
  variable: string;
}

interface Props {
  family: string;
  tones: Tone[];
}

const { family, tones } = Astro.props;
---

<section class="not-content ramp">
  <h3 class="ramp-title">{family}</h3>
  <ol class="ramp-strip" style={`--ramp-count: ${tones.length}`}>
    {
      tones.map((t) => (
        <li class="ramp-step">
          <button
            type="button"
            class="ramp-trigger"
            data-color-chip
            data-variable={t.variable}
            aria-label={`Copy ${family} ${t.label} (${t.variable})`}
          >
            <span
              class="ramp-chip"
              data-color-swatch
              style={`background: var(${t.variable})`}
              aria-hidden="true"
            />
            <span class="ramp-label">{t.label}</span>
          </button>
        </li>
      ))
    }
  </ol>
</section>

<style>
  .ramp {
    padding: 0.75rem 0;
    border-top: 1px solid var(--sl-color-hairline);
  }
  .ramp:first-of-type {
    border-top: none;
    padding-top: 0.25rem;
  }
  .ramp-title {
    font-size: 0.85rem;
    font-weight: 600;
    margin: 0 0 0.5rem;
  }
  .ramp-strip {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(var(--ramp-count), minmax(0, 1fr));
    gap: 0.25rem;
  }
  .ramp-step {
    min-width: 0;
  }
  .ramp-trigger {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    width: 100%;
    padding: 0;
    background: transparent;
    border: 0;
    text-align: center;
    cursor: pointer;
    font: inherit;
    color: inherit;
    border-radius: 0.3rem;
  }
  .ramp-trigger:focus-visible {
    outline: 2px solid var(--sl-color-text-accent);
    outline-offset: 2px;
  }
  .ramp-chip {
    display: block;
    aspect-ratio: 1;
    border-radius: 0.25rem;
    border: 1px solid var(--sl-color-hairline);
    transition: transform 120ms ease;
  }
  .ramp-trigger:hover .ramp-chip {
    transform: translateY(-1px);
  }
  .ramp-label {
    font-size: 0.6rem;
    font-variant-numeric: tabular-nums;
    color: var(--sl-color-text-accent);
    line-height: 1;
  }
  @media (max-width: 50rem) {
    .ramp-label {
      font-size: 0.55rem;
    }
  }
</style>
