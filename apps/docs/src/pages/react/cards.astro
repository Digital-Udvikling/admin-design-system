---
import { Button, Card, Input } from "@aortl/admin-react";
import Example from "../../components/Example.astro";
import Layout from "../../layouts/Layout.astro";
---

<Layout title="React — Cards">
  <h1 class="text-3xl font-bold mb-2">Card</h1>
  <p class="text-text-muted text-lg mb-8">
    Container plus dot-notation parts: <code>Card.Body</code>, <code>Card.Title</code>,
    <code>Card.Description</code>, <code>Card.Actions</code>.
  </p>

  <Example
    title="Basic"
    lang="tsx"
    code={`<Card>
  <Card.Body>
    <Card.Title>Welcome</Card.Title>
    <Card.Description>A short description sits here.</Card.Description>
    <Card.Actions>
      <Button size="sm">Get started</Button>
      <Button variant="ghost" size="sm">Maybe later</Button>
    </Card.Actions>
  </Card.Body>
</Card>`}
  >
    <div class="w-full max-w-sm">
      <Card>
        <Card.Body>
          <Card.Title>Welcome</Card.Title>
          <Card.Description>A short description sits here.</Card.Description>
          <Card.Actions>
            <Button size="sm">Get started</Button>
            <Button variant="ghost" size="sm">Maybe later</Button>
          </Card.Actions>
        </Card.Body>
      </Card>
    </div>
  </Example>

  <Example
    title="Sign-in form"
    lang="tsx"
    code={`<Card>
  <Card.Body>
    <Card.Title>Sign in</Card.Title>
    <Input placeholder="Email" />
    <Input type="password" placeholder="Password" />
    <Card.Actions>
      <Button>Sign in</Button>
      <Button variant="ghost">Cancel</Button>
    </Card.Actions>
  </Card.Body>
</Card>`}
  >
    <div class="w-full max-w-sm">
      <Card>
        <Card.Body>
          <Card.Title>Sign in</Card.Title>
          <Input placeholder="Email" />
          <Input type="password" placeholder="Password" />
          <Card.Actions>
            <Button>Sign in</Button>
            <Button variant="ghost">Cancel</Button>
          </Card.Actions>
        </Card.Body>
      </Card>
    </div>
  </Example>

  <Example
    title="Compact + bordered"
    lang="tsx"
    code={`<Card compact bordered>
  <Card.Body>
    <Card.Title>Flat & dense</Card.Title>
    <Card.Description>Less padding, stronger border, no shadow.</Card.Description>
  </Card.Body>
</Card>`}
  >
    <div class="w-full max-w-sm">
      <Card compact bordered>
        <Card.Body>
          <Card.Title>Flat & dense</Card.Title>
          <Card.Description>Less padding, stronger border, no shadow.</Card.Description>
        </Card.Body>
      </Card>
    </div>
  </Example>
</Layout>
