---
import { Code, TabItem, Tabs } from "@astrojs/starlight/components";

interface Props {
  /** Pre-formatted HTML source. Drives the vanilla preview and the HTML tab. */
  html?: string;
  /** Pre-formatted React source. Drives the React tab. */
  react?: string;
}

const { html, react } = Astro.props;
const hasReact = !!react;
const hasBoth = !!html && hasReact;
---

<section class="not-content example-block">
  <div class="example-frame">
    {
      hasBoth ? (
        <package-preview class="example-preview">
          <div class="preview-variant" data-variant="html" set:html={html!} />
          <div class="preview-variant" data-variant="react" hidden>
            <slot name="preview" />
          </div>
        </package-preview>
      ) : (
        <div class="example-preview">
          {hasReact ? (
            <slot name="preview" />
          ) : html ? (
            <Fragment set:html={html} />
          ) : null}
        </div>
      )
    }
    <div class="example-source">
      {
        hasBoth ? (
          <Tabs syncKey="package">
            <TabItem label="Vanilla CSS">
              <Code code={html!} lang="html" />
            </TabItem>
            <TabItem label="React">
              <Code code={react!} lang="tsx" />
            </TabItem>
          </Tabs>
        ) : html ? (
          <Code code={html} lang="html" />
        ) : react ? (
          <Code code={react} lang="tsx" />
        ) : null
      }
    </div>
  </div>
</section>

{/* Hoisted module so Astro bundles and dedupes it across the page. The
storage key, sync attribute, and tab selectors below intentionally track
@astrojs/starlight/user-components/Tabs.astro — keep them in sync. */}
<script>
  const STORAGE_KEY = "starlight-synced-tabs__package";

  class PackagePreview extends HTMLElement {
    #observer: MutationObserver | null = null;
    #onStorage = (e: StorageEvent) => {
      if (e.key === STORAGE_KEY && e.newValue) this.#apply(e.newValue);
    };

    connectedCallback() {
      if (this.querySelectorAll(".preview-variant").length < 2) return;

      const stored = localStorage.getItem(STORAGE_KEY);
      if (stored) this.#apply(stored);

      const tabs = this.parentElement?.querySelector(
        'starlight-tabs[data-sync-key="package"]',
      );
      if (tabs) {
        this.#observer = new MutationObserver(() => {
          const tab = tabs.querySelector('[role="tab"][aria-selected="true"]');
          const label = tab?.textContent?.trim();
          if (label) this.#apply(label);
        });
        this.#observer.observe(tabs, {
          attributes: true,
          attributeFilter: ["aria-selected"],
          subtree: true,
        });
      }

      window.addEventListener("storage", this.#onStorage);
    }

    disconnectedCallback() {
      this.#observer?.disconnect();
      this.#observer = null;
      window.removeEventListener("storage", this.#onStorage);
    }

    #apply(label: string) {
      const wantReact = label === "React";
      for (const v of this.querySelectorAll<HTMLElement>(".preview-variant")) {
        const isReact = v.dataset.variant === "react";
        v.hidden = wantReact ? !isReact : isReact;
      }
    }
  }

  customElements.define("package-preview", PackagePreview);
</script>

<style>
  .example-block {
    margin: 1.5rem 0 2rem;
  }
  .example-frame {
    border: 1px solid var(--sl-color-hairline);
    border-radius: 0.5rem;
    overflow: hidden;
    background: var(--sl-color-bg);
  }
  .example-preview {
    padding: 1.5rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem;
    border-bottom: 1px solid var(--sl-color-hairline);
    background: var(--color-surface);
  }
  /* Vanilla `.tooltip-wrap` tooltips render inside the trigger's stacking
  context, so the frame's `overflow: hidden` (needed for rounded corners)
  clips them. Give the preview enough padding to contain a top/bottom/side
  tooltip without changing the frame's overflow behavior. */
  .example-preview:has(.tooltip-wrap) {
    padding: 3rem;
  }
  /* Variants are layout-transparent so children flex directly in the
  preview. The explicit [hidden] rule outranks display: contents. */
  .example-preview .preview-variant {
    display: contents;
  }
  .example-preview .preview-variant[hidden] {
    display: none;
  }
  .example-source :global(starlight-tabs),
  .example-source :global(div[role="tabpanel"]) {
    margin-top: 0;
  }
  .example-source :global(.tablist-wrapper) {
    background: var(--sl-color-bg-nav);
  }
  .example-source :global(pre) {
    margin: 0;
    border-radius: 0;
    border: none;
  }
</style>
