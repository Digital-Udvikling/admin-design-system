{
  "name": "admin",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r --filter=!docs build && pnpm --filter docs build",
    "build:css": "pnpm --filter @aortl/admin-css build",
    "build:react": "pnpm --filter @aortl/admin-react build",
    "dev": "pnpm --filter docs dev",
    "check-types": "pnpm --filter @aortl/admin-react check-types && pnpm --filter docs check-types",
    "clean": "pnpm -r exec rm -rf dist .astro node_modules/.vite"
  },
  "devDependencies": {
    "typescript": "5.8.3"
  },
  "packageManager": "pnpm@10.13.1",
  "engines": {
    "node": ">=22"
  }
}
