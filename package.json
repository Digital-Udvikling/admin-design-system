{
  "name": "admin",
  "version": "0.18.3",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r --filter=!docs build && pnpm --filter docs build",
    "build:css": "pnpm --filter @aortl/admin-css build",
    "build:react": "pnpm --filter @aortl/admin-react build",
    "dev": "pnpm --filter @aortl/admin-css build && pnpm --parallel --filter @aortl/admin-css --filter docs dev",
    "check-types": "pnpm --filter @aortl/admin-react check-types && pnpm --filter docs check-types",
    "test": "pnpm -r --filter='@aortl/*' run test",
    "generate-skill": "pnpm --filter docs generate-skill",
    "release": "release-it",
    "clean": "pnpm -r exec rm -rf dist .astro node_modules/.vite",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "prepare": "husky"
  },
  "devDependencies": {
    "@release-it/bumper": "7.0.6",
    "@release-it/keep-a-changelog": "7.1.0",
    "husky": "9.1.7",
    "oxfmt": "0.50.0",
    "oxlint": "1.65.0",
    "release-it": "20.2.0",
    "typescript": "5.8.3"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.13.1"
}
