---
interface Variant {
  label: string;
  variable: string;
}

interface Props {
  family: string;
  description?: string;
  variants: Variant[];
}

const { family, description, variants } = Astro.props;
---

<section class="not-content family">
  <header class="family-head">
    <h3 class="family-title">{family}</h3>
    {description && <p class="family-desc">{description}</p>}
  </header>
  <ul class="family-strip">
    {
      variants.map((v) => (
        <li class="variant">
          <button
            type="button"
            class="variant-trigger"
            data-color-chip
            data-variable={v.variable}
            aria-label={`Copy ${v.label} (${v.variable})`}
          >
            <span
              class="variant-chip"
              data-color-swatch
              style={`background: var(${v.variable})`}
              aria-hidden="true"
            />
            <span class="variant-meta">
              <span class="variant-label">{v.label}</span>
              <code class="variant-var">{v.variable}</code>
            </span>
          </button>
        </li>
      ))
    }
  </ul>
</section>

<style>
  .family {
    display: grid;
    grid-template-columns: minmax(0, 9rem) minmax(0, 1fr);
    gap: 1.5rem;
    align-items: start;
    padding: 1.25rem 0;
    border-top: 1px solid var(--sl-color-hairline);
  }
  .family:first-of-type {
    border-top: none;
    padding-top: 0.5rem;
  }
  @media (max-width: 50rem) {
    .family {
      grid-template-columns: 1fr;
      gap: 0.75rem;
    }
  }
  .family-head {
    position: sticky;
    top: 5rem;
  }
  .family-title {
    font-size: 0.95rem;
    font-weight: 600;
    margin: 0 0 0.25rem;
  }
  .family-desc {
    font-size: 0.78rem;
    color: var(--sl-color-text-accent);
    margin: 0;
    line-height: 1.4;
  }
  .family-strip {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.75rem;
  }
  @media (max-width: 40rem) {
    .family-strip {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
  .variant {
    min-width: 0;
  }
  .variant-trigger {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    width: 100%;
    padding: 0;
    background: transparent;
    border: 0;
    text-align: left;
    cursor: pointer;
    font: inherit;
    color: inherit;
    border-radius: 0.5rem;
  }
  .variant-trigger:focus-visible {
    outline: 2px solid var(--sl-color-text-accent);
    outline-offset: 3px;
  }
  .variant-chip {
    display: block;
    height: 3.5rem;
    border-radius: 0.5rem;
    border: 1px solid var(--sl-color-hairline);
    box-shadow: inset 0 0 0 1px rgb(255 255 255 / 0.04);
    transition: transform 120ms ease;
  }
  .variant-trigger:hover .variant-chip {
    transform: translateY(-1px);
  }
  .variant-meta {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    min-width: 0;
  }
  .variant-label {
    font-size: 0.78rem;
    font-weight: 600;
  }
  .variant-var {
    font-size: 0.68rem;
    color: var(--sl-color-text-accent);
    background: transparent;
    padding: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
</style>
